# Server Configuration
PORT=5000
JWT_SECRET=kollab_super_secret_jwt_key_987654321
CLIENT_URL=http://localhost:5173

# Database Connection (Neon PostgreSQL)
# Replace with your Neon connection string: postgresql://<user>:<password>@<host>/<database>?sslmode=require
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/kollab?schema=public"

# SMTP Configuration for RSVP Email Confirmations
# If left blank, the server will auto-generate a mock SMTP account (via Ethereal Email) 
# and print the verification links/emails directly to the console for testing.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="KOLLAB RSVP <rsvp@kollab.com>"
